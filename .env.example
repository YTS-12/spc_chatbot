# ===== 필수: 현재 코드가 실제로 사용하는 키 =====
OPENAI_API_KEY=
PINECONE_API_KEY=

# Pinecone 인덱스(현재 라이브 값)
PINECONE_INDEX_NAME=kifrs-proto-index
PINECONE_NAMESPACE=kifrs-proto-v1
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# ===== 모델 / 임베딩 =====
# 주의: EMBEDDING_MODEL / EMBEDDING_DIMENSION 을 바꾸면 반드시 재임베딩 +
#       새 namespace(또는 ingest --reset)로 인덱스를 다시 만들어야 한다.
#       (현재 라이브 인덱스는 text-embedding-3-small / 1536 차원)
#       업그레이드 예) text-embedding-3-large / 3072
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
CHAT_MODEL=gpt-5.4-mini

# ===== 청킹 / 검색 / 재시도 튜닝(재임베딩 없이 즉시 반영되는 것 포함) =====
CHUNK_SIZE=900
CHUNK_OVERLAP=150
TOP_K=6
MAX_RETRY=2
# 검색 방식: mmr(다양성, 기본) | similarity | similarity_score_threshold
SEARCH_TYPE=mmr
MMR_FETCH_K=20
MMR_LAMBDA=0.5
SCORE_THRESHOLD=0.0
# 재시도 재작성 시 변형을 주기 위한 temperature(원본 grade/generate는 0 유지)
RETRY_TEMPERATURE=0.7

# ===== Rerank(재정렬) — 기본 비활성. 백엔드 준비 후 true =====
# local : pip install transformers  (torch 필요; 모델 최초 1회 다운로드)
# cohere: pip install cohere + COHERE_API_KEY
RERANK_ENABLED=false
RERANK_PROVIDER=local
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_FETCH_K=20
COHERE_API_KEY=

# ===== 섹션 필터(1층) + 온톨로지(2층) — 기본 ON =====
# 본문(body) 우선: 결론도출근거(basis)/소수의견(minority)/목차(toc) 제외
SECTION_FILTER_ENABLED=true
ALLOWED_SECTION_TYPES=body,example
# include_basis 개념(예: SPC)일 때 결론도출근거(basis)에 보장할 결과 슬롯 수
BASIS_RESERVE=2
# 개념->기준서 라우팅(메타데이터 필터) + 쿼리 그라운딩
ONTOLOGY_FILTER_ENABLED=true
ONTOLOGY_GROUNDING=true
# 라우팅 정밀도: 흔한 단어 무시 + 점수화 + 최종 기준서 상한(0=무제한). false면 과거 방식.
ROUTING_STRICT=true
ROUTING_MAX_CONCEPTS=5
ROUTING_MAX_STANDARDS=4

# ===== 하이브리드 검색(dense + BM25/RRF) — pip install rank_bm25 필요 =====
# 번호/정확 용어 매칭 보완. chunks_cache.jsonl(적재 시 생성) 사용. 없으면 dense-only.
HYBRID_ENABLED=true
RRF_K=60

# ===== 인제스트(재적재 시 적용) 튜닝 =====
MIN_CHUNK_CHARS=50
EMBED_BATCH_SIZE=100

# ===== (선택) 현재 코드 경로에서는 미사용 — 향후 확장/다른 스크립트용 =====
TAVILY_API_KEY=
KRXDATA_API_KEY=
OPEN_DART_API_KEY=
ECOS_API_KEY=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
REDIS_URL=
MEILI_HOST=
MEILI_MASTER_KEY=
